{
  "name": "sbomtest",
  "version": "2.0.0",
  "description": "Gera arquivos .md com testes externos relevantes usando SBOM + Horsebox.",
  "main": "src/index.ts",
  "bin": {
    "sbomtest": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "start": "bun run src/index.ts",
    "sbomtest": "bun run src/index.ts",
    "test": "bun test --isolate",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "lint:report": "eslint src/**/*.ts tests/**/*.ts -f json -o reports/eslint-report.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sbom",
    "cyclonedx",
    "horsebox",
    "code-search",
    "dependency-analysis"
  ],
  "license": "ISC",
  "dependencies": {
    "@babel/parser": "^7.28.0",
    "@cyclonedx/cyclonedx-npm": "^4.2.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "typescript": "^6.0.3"
  }
}
